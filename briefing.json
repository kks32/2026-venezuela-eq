  "sections": [
    {
      "section": "introduction",
      "title": "Introduction",
      "clauses": [
        {
          "text": "The event was a doublet: an M7.2 foreshock followed shortly by an M7.5 mainshock. Earlier preliminary reports of M7.1, carried widely across syndicated outlets, are superseded by the official USGS solution and are retained as disputed.",
          "claim_ids": [
            "usgs-fdsn::magnitude::0",
            "usgs-fdsn::magnitude::1",
            "ref-2::magnitude::0"
          ],
          "source_refs": [
            "abc7.com",
            "earthquake.usgs.gov"
          ],
          "entailed": true
        },
        {
          "text": "The hypocentral depth is about 10 km km.",
          "claim_ids": [
            "usgs-fdsn::depth_km::2"
          ],
          "source_refs": [
            "earthquake.usgs.gov"
          ],
          "entailed": true
        },
        {
          "text": "The epicenter was located 28 km SE of Yumare, Venezuela.",
          "claim_ids": [
            "usgs-fdsn::location::4"
          ],
          "source_refs": [
            "earthquake.usgs.gov"
          ],
          "entailed": true
        },
        {
          "text": "Epicentral coordinates are 10.44N, 68.47W.",
          "claim_ids": [
            "usgs-fdsn::epicenter::3"
          ],
          "source_refs": [
            "earthquake.usgs.gov"
          ],
          "entailed": true
        },
        {
          "text": "Modeled peak shaking intensity reached about MMI 9.",
          "claim_ids": [
            "usgs-shakemap::max_mmi::0"
          ],
          "source_refs": [
            "earthquake.usgs.gov"
          ],
          "entailed": true
        }
      ]
    },
    {
